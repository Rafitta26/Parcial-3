package com.motorjuego;

import java.util.ArrayList;
import java.util.List;

public class MotorJuego {
    private EstadoJuego estadoActual;
    private List<EntidadVideojuego> entidades;
    private EntidadVideojuego jugador;

    public MotorJuego() {
        this.estadoActual = EstadoJuego.MENU;
        this.entidades = new ArrayList<>();
    }

    public void iniciarPartida() {
        this.estadoActual = EstadoJuego.JUGANDO;
        this.entidades.clear();
        
        // Spawn original del escenario
        this.jugador = new Jugador("Héroe Medieval", 0, 0);
        this.entidades.add(jugador);
        
        System.out.println("LOG [MOTOR]: Partida inicializada.");
    }

    public void agregarEntidad(EntidadVideojuego entidad) {
        this.entidades.add(entidad);
        System.out.println("LOG [SPAWN]: " + entidad.getNombre() + " entra al mapa en (" + entidad.getX() + "," + entidad.getY() + ")");
    }

    public void desplazarJugador(String direccion) {
        if (this.estadoActual != EstadoJuego.JUGANDO) return;
        switch (direccion.toUpperCase()) {
            case "ARRIBA":    jugador.setY(jugador.getY() - 1); break;
            case "ABAJO":     jugador.setY(jugador.getY() + 1); break;
            case "IZQUIERDA": jugador.setX(jugador.getX() - 1); break;
            case "DERECHA":   jugador.setX(jugador.getX() + 1); break;
        }
        System.out.println("LOG [INPUT]: Jugador se mueve a (" + jugador.getX() + "," + jugador.getY() + ")");
    }

    // --- REQUISITO AVANZADO: Detector de Colisiones Simple (AABB) ---
    private void procesarColisiones() {
        // Comparamos todas las entidades entre sí
        for (int i = 0; i < entidades.size(); i++) {
            for (int j = i + 1; j < entidades.size(); j++) {
                EntidadVideojuego e1 = entidades.get(i);
                EntidadVideojuego e2 = entidades.get(j);

                // Verificación matemática (Invocando el método matemático heredado)
                if (e1.colisionaCon(e2)) {
                    System.out.println("⚡ LOG [COLISIÓN]: ¡Impacto detectado entre " + e1.getNombre() + " y " + e2.getNombre() + "!");
                    
                    // Consecuencias de juego simuladas según los tipos
                    resolverImpacto(e1, e2);
                }
            }
        }
    }

    private void resolverImpacto(EntidadVideojuego e1, EntidadVideojuego e2) {
        // Caso: Jugador choca con Enemigo
        if ((e1 instanceof Jugador && e2 instanceof Enemigo) || (e2 instanceof Jugador && e1 instanceof Enemigo)) {
            jugador.recibirDanio(25); // El enemigo hiere al jugador
            System.out.println("💥 LOG [COMBATE]: El enemigo causa daño. Vida restante del Héroe: " + jugador.getVida() + "%");
        }
    }

    // Game Loop
    public void actualizar() {
        if (this.estadoActual != EstadoJuego.JUGANDO) return;

        System.out.println("\n--- [TOCK REFRESH] ---");
        
        // 1. Actualiza posiciones/comportamientos de IA
        for (EntidadVideojuego entidad : entidades) {
            entidad.actualizar(this.jugador);
        }

        // 2. Ejecuta el detector de colisiones avanzado
        procesarColisiones();

        // 3. Verificación de derrota
        if (jugador.getVida() <= 0) {
            this.estadoActual = EstadoJuego.GAME_OVER;
            System.out.println("LOG [ESTADO]: El Jugador ha caído en combate. Fin de la partida.");
        }
    }

    public EstadoJuego getEstadoActual() { return estadoActual; }
    public EntidadVideojuego getJugador() { return jugador; }
}

