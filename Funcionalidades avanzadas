// --- CLASE ENEMIGO ---
class Enemigo extends EntidadVideojuego {
    private String estadoIA; // PATRULLAR, PERSEGUIR, ATACAR
    
    // Distancias límite para la toma de decisiones de la IA
    private static final int DISTANCIA_PERSEGUIR = 5;
    private static final int DISTANCIA_ATACAR = 1; 

    public Enemigo(String nombre, int x, int y) {
        super(nombre, x, y, 1, 1, 40, "sprite_orco.png");
        this.estadoIA = "PATRULLAR";
    }

    // REQUISITO AVANZADO: Comportamiento básico NPC del Enemigo
    @Override
    public void actualizar(EntidadVideojuego jugador) {
        if (jugador == null || jugador.getVida() <= 0) return;

        // Calculamos la distancia Manhattan: |x1 - x2| + |y1 - y2|
        int distancia = Math.abs(this.getX() - jugador.getX()) + Math.abs(this.getY() - jugador.getY());

        // Transición de estados de la IA basada en la distancia
        if (distancia <= DISTANCIA_ATACAR) {
            this.estadoIA = "ATACAR";
            System.out.println("LOG [IA ENEMIGO]: [" + getNombre() + "] cambia a estado ¡ATACAR! Lanzando golpe.");
        } else if (distancia <= DISTANCIA_PERSEGUIR) {
            this.estadoIA = "PERSEGUIR";
            System.out.println("LOG [IA ENEMIGO]: [" + getNombre() + "] cambia a estado PERSEGUIR. Avistado el Héroe.");
            
            // Persecución inteligente en cuadrícula (avanza 1 casilla hacia el jugador)
            if (this.getX() < jugador.getX()) this.setX(this.getX() + 1);
            else if (this.getX() > jugador.getX()) this.setX(this.getX() - 1);
            
            if (this.getY() < jugador.getY()) this.setY(this.getY() + 1);
            else if (this.getY() > jugador.getY()) this.setY(this.getY() - 1);
        } else {
            this.estadoIA = "PATRULLAR";
            System.out.println("LOG [IA ENEMIGO]: [" + getNombre() + "] en estado PATRULLAR. Zona segura.");
            this.setX(this.getX() + (int)(Math.random() * 3) - 1);
        }
    }

    public String getEstadoIA() { return estadoIA; }
}

