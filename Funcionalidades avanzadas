package com.motorjuego;

public class Main {
    public static void main(String[] args) {
        System.out.println("=========================================================");
        System.out.println("DEMOSTRACIÓN: FUNCIONALIDADES AVANZADAS (PARTE 4)");
        System.out.println("=========================================================\n");

        MotorJuego motor = new MotorJuego();
        motor.iniciarPartida(); // El jugador spawnea en (0,0)

        // Colocamos un Orco a distancia de Patrulla (distancia Manhattan = 6)
        Enemigo orco = new Enemigo("Orco Berserker", 6, 0);
        motor.agregarEntidad(orco);

        // --- ESCENARIO 1: Distancia Lejana (Patrullar) ---
        System.out.println("\n>>> Escenario 1: Enemigo lejos del jugador");
        motor.actualizar(); 

        // --- ESCENARIO 2: Acercamiento (Perseguir) ---
        System.out.println("\n>>> Escenario 2: El jugador se aproxima al peligro");
        motor.desplazarJugador("DERECHA");
        motor.desplazarJugador("DERECHA"); // Jugador ahora está en (2,0). Distancia = 4.
        motor.actualizar(); // La IA cambia a PERSEGUIR y da un paso acortando a (5,0)

        // --- ESCENARIO 3: Combate Cuerpo a Cuerpo (Atacar y Colisionar) ---
        System.out.println("\n>>> Escenario 3: Entrada en rango de ataque y colisión física");
        motor.desplazarJugador("DERECHA");
        motor.desplazarJugador("DERECHA"); // Jugador avanza a (4,0). El Orco está en (5,0). Distancia = 1.
        motor.actualizar(); // El Orco pasa a ATACAR y se mueve a (4,0) compartiendo caja espacial.
        
        // Se dispara automáticamente el detector de colisiones en este mismo frame
        System.out.println("\nEstado final del Motor tras el combate: " + motor.getEstadoActual());
        System.out.println("=========================================================");
    }
}
