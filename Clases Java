    }

    @Override
    public void actualizar(EntidadVideojuego jugador) {
        // La lógica del jugador se maneja por inputs, no requiere auto-actualización por ahora
    }
}


class Enemigo extends EntidadVideojuego {
    private String estadoIA; // PATRULLAR o PERSEGUIR
    private static final int DISTANCIA_ALERTA = 4; // Umbral de distancia simulada

    public Enemigo(String nombre, int x, int y) {
        super(nombre, x, y, 1, 1, 30, "sprite_orco.png");
        this.estadoIA = "PATRULLAR";
    }

  
    @Override
    public void actualizar(EntidadVideojuego jugador) {
        if (jugador == null) return;

        int distancia = Math.abs(this.getX() - jugador.getX()) + Math.abs(this.getY() - jugador.getY());

        if (distancia <= DISTANCIA_ALERTA) {
            this.estadoIA = "PERSEGUIR";
            // Persecución simulada simple en eje X
            if (this.getX() < jugador.getX()) this.setX(this.getX() + 1);
            else if (this.getX() > jugador.getX()) this.setX(this.getX() - 1);
        } else {
            this.estadoIA = "PATRULLAR";
            // Patrulla simulada oscilando de lado a lado de forma básica
            this.setX(this.getX() + (Math.random() > 0.5 ? 1 : -1));
        }
        System.out.println("LOG: [" + getNombre() + "] Estado IA: " + estadoIA + " en posición (" + getX() + "," + getY() + ")");
    }
}

package com.motorjuego;

import java.util.ArrayList;
import java.util.List;

public class MotorJuego {
    private EstadoJuego estadoActual;
    private List<EntidadVideojuego> entidades;
    private EntidadVideojuego jugador;

    public MotorJuego() {
        this.estadoActual = EstadoJuego.MENU;
        this.entidades = new ArrayList<>();
    }

    public void iniciarPartida() {
        if (this.estadoActual == EstadoJuego.JUGANDO) {
            System.out.println("LOG: Ya hay una partida en curso.");
            return;
        }
        this.estadoActual = EstadoJuego.JUGANDO;
        this.entidades.clear();
        
        this.jugador = new Jugador("Héroe Medieval", 0, 0);
        this.entidades.add(jugador);
        this.entidades.add(new Enemigo("Orco Explorador", 5, 0));
        
        System.out.println("LOG: Partida Iniciada. Héroe y Orco creados.");
    }

    public void pausarReanudar() {
        if (this.estadoActual == EstadoJuego.JUGANDO) {
            this.estadoActual = EstadoJuego.PAUSA;
            System.out.println("LOG: Juego Pausado.");
        } else if (this.estadoActual == EstadoJuego.PAUSA) {
            this.estadoActual = EstadoJuego.JUGANDO;
            System.out.println("LOG: Juego Reanudado.");
        }
    }

    public void actualizar() {
        if (this.estadoActual != EstadoJuego.JUGANDO) {
            System.out.println("LOG: El juego no está en modo activo. Estado actual: " + estadoActual);
            return;
        }

        System.out.println("\n--- SIMULACIÓN TOCK DE ACTUALIZACIÓN ---");
        
        for (EntidadVideojuego entidad : entidades) {
            entidad.actualizar(jugador);
        }

        verificarColisiones();

        // 3. Verificar condición de Game Over
        if (jugador.getVida() <= 0) {
            this.estadoActual = EstadoJuego.GAME_OVER;
            System.out.println("LOG: ¡GAME OVER! El jugador ha sido derrotado.");
        }
    }

    private void verificarColisiones() {
        for (int i = 0; i < entidades.size(); i++) {
            for (int j = i + 1; j < entidades.size(); j++) {
                EntidadVideojuego e1 = entidades.get(i);
                EntidadVideojuego e2 = entidades.get(j);

                if (e1.colisionaCon(e2)) {
                    System.out.println("LOG WARNING: ¡Colisión detectada entre " + e1.getNombre() + " y " + e2.getNombre() + "!");
                    // Efecto simulado de daño mutuo/interacción
                    e1.recibirDanio(20);
                    e2.recibirDanio(30);
                    System.out.println("LOG: Vidas actuales -> " + e1.getNombre() + ": " + e1.getVida() + " | " + e2.getNombre() + ": " + e2.getVida());
                }
            }
        }
    }

    public EstadoJuego getEstadoActual() { return estadoActual; }
    public EntidadVideojuego getJugador() { return jugador; }
}
package com.motorjuego;

public class SistemaPuntuacion {
    private int puntos;
    private int enemigosEliminados;

    public SistemaPuntuacion() {
        this.puntos = 0;
        this.enemigosEliminados = 0;
    }

    public void sumarPuntos(int cantidad) {
        this.puntos += cantidad;
        System.out.println("LOG PUNTOS: +" + cantidad + " puntos conseguidos. Total: " + this.puntos);
    }

    public void registrarBaja() {
        this.enemigosEliminados++;
        sumarPuntos(100);
        System.out.println("LOG ESTADÍSTICAS: Enemigos eliminados: " + enemigosEliminados);
    }

    public int getPuntos() { return puntos; }
}

